<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>
        <section>
            <h2>Upcoming Service Projects</h2>
            <ul>
                <% serviceProjects.forEach(project=> { %>
                    <li><strong>
                            <%= project.date.toLocaleDateString('en-US', { year: 'numeric' , month: 'long' ,
                                day: 'numeric' }) %>
                        </strong>: <%= project.title %> (<%= project.organization_name %>)
                    </li>
                    <% }); %>
            </ul>
        </section>
    </main>
    <%- include('partials/footer') %>